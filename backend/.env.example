APP_ENV=development
HOST=0.0.0.0
PORT=8002
LOG_LEVEL=INFO
AUTH_SESSION_SECRET=replace-with-long-random-session-secret
AUTH_LAUNCH_SECRET=replace-with-long-random-launch-secret
AUTH_USER_HASH_SALT=replace-with-stable-user-hash-salt
AUTH_SESSION_TTL_SECONDS=3600
AUTH_ALLOW_DEMO_MODE=true
AUTH_DEMO_DISPLAY_NAME=Demo User
AUTH_DEMO_TENANT_ID=tenant_demo
AUTH_DEFAULT_APP_NAME=HermanPrompt
AUTH_DEFAULT_THEME=dark
PROMPT_TRANSFORMER_URL=https://prompttranformer-production.up.railway.app
PROMPT_TRANSFORMER_API_KEY=
PROMPT_TRANSFORMER_CLIENT_ID=hermanprompt
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=800
LLM_TIMEOUT_SECONDS=45
DATABASE_URL=sqlite:///./hermanprompt.db
CORS_ALLOWED_ORIGINS=http://localhost:5173
